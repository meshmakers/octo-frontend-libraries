{
  "name": "client-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node aspnetcore-https",
    "start": "run-script-os",
    "start:windows": "ng serve --port 44484 --host=0.0.0.0 --ssl --ssl-cert %APPDATA%\\ASP.NET\\https\\%npm_package_name%.pem --ssl-key %APPDATA%\\ASP.NET\\https\\%npm_package_name%.key",
    "start:default": "ng serve --port 44484 --host=0.0.0.0 --ssl --ssl-cert $HOME/.aspnet/https/${npm_package_name}.pem --ssl-key $HOME/.aspnet/https/${npm_package_name}.key",
    "build": "npm run build:shared-services && npm run build:shared-auth && npm run build:shared-ui && npm run build:octo-services && npm run build:octo-ui && npm run build:test-app",
    "build:prod": "npm run build:shared-services -- --configuration=production && npm run build:shared-auth -- --configuration=production && npm run build:shared-ui -- --configuration=production && npm run build:octo-services -- --configuration=production && npm run build:octo-ui -- --configuration=production && npm run build:test-app -- --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:shared-auth": "ng lint @meshmakers/shared-auth && ng build @meshmakers/shared-auth",
    "build:shared-ui": "ng lint @meshmakers/shared-ui && ng build @meshmakers/shared-ui",
    "build:octo-ui": "ng lint @meshmakers/octo-ui && ng build @meshmakers/octo-ui",
    "build:octo-services": "ng lint @meshmakers/octo-services && ng build @meshmakers/octo-services",
    "build:shared-services": "ng lint @meshmakers/shared-services && ng build @meshmakers/shared-services",
    "watch:shared-auth": "ng build @meshmakers/shared-auth --watch --configuration development",
    "watch:shared-services": "ng build @meshmakers/shared-services --watch --configuration development",
    "watch:shared-ui": "ng build @meshmakers/shared-ui --watch --configuration development",
    "watch:octo-ui": "ng build @meshmakers/octo-ui --watch --configuration development",
    "build:test-app": "ng build --project test-app",
    "postinstall": "node environments/version.ts",
    "codegen": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 graphql-codegen --config codegen.yml",
    "link-dist": "cd dist/meshmakers/shared-auth && npm link && cd ../shared-services && npm link && cd ../shared-ui && npm link && cd ../octo-services && npm link && cd ../octo-ui && npm link",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.1.6",
    "@angular/cdk": "^20.1.5",
    "@angular/common": "^20.1.6",
    "@angular/compiler": "^20.1.6",
    "@angular/core": "^20.1.6",
    "@angular/forms": "^20.1.6",
    "@angular/material": "^20.1.5",
    "@angular/platform-browser": "^20.1.6",
    "@angular/platform-browser-dynamic": "^20.1.6",
    "@angular/router": "^20.1.6",
    "angular-oauth2-oidc": "^20.0.2",
    "apollo-angular": "11.0.0",
    "aspnet-prerendering": "^3.0.1",
    "date-fns": "^4.1.0",
    "material-symbols": "^0.34.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.1.5",
    "@angular/cli": "^20.1.5",
    "@angular/compiler-cli": "^20.1.6",
    "@eslint/js": "^9.33.0",
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/near-operation-file-preset": "^3.1.0",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.1",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@types/jasmine": "~5.1.8",
    "@types/node": "^24.2.1",
    "@types/w3c-web-nfc": "^1.0.4",
    "angular-eslint": "20.1.1",
    "cross-env": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jasmine-core": "~5.10.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^20.1.0",
    "run-script-os": "^1.1.6",
    "typescript": "~5.8.3",
    "typescript-eslint": "8.39.1"
  }
}
