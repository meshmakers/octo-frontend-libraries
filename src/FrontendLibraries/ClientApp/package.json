{
  "name": "client-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node aspnetcore-https",
    "start": "run-script-os",
    "start:windows": "ng serve --port 44484 --host=0.0.0.0 --ssl --ssl-cert %APPDATA%\\ASP.NET\\https\\%npm_package_name%.pem --ssl-key %APPDATA%\\ASP.NET\\https\\%npm_package_name%.key",
    "start:default": "ng serve --port 44484 --host=0.0.0.0 --ssl --ssl-cert $HOME/.aspnet/https/${npm_package_name}.pem --ssl-key $HOME/.aspnet/https/${npm_package_name}.key",
    "build": "npm run lint && npm run build:shared-services && npm run build:shared-auth && npm run build:shared-ui && npm run build:octo-services && npm run build:octo-ui && npm run build:test-app",
    "build:prod": "npm run lint && npm run build:shared-services -- --configuration=production && npm run build:shared-auth -- --configuration=production && npm run build:shared-ui -- --configuration=production && npm run build:octo-services -- --configuration=production && npm run build:octo-ui -- --configuration=production && npm run build:test-app -- --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:shared-auth": "ng build @meshmakers/shared-auth",
    "build:shared-ui": "ng build @meshmakers/shared-ui",
    "build:octo-ui": "ng build @meshmakers/octo-ui",
    "build:octo-services": "ng build @meshmakers/octo-services",
    "build:shared-services": "ng build @meshmakers/shared-services",
    "watch:shared-auth": "ng build @meshmakers/shared-auth --watch --configuration development",
    "watch:shared-services": "ng build @meshmakers/shared-services --watch --configuration development",
    "watch:shared-ui": "ng build @meshmakers/shared-ui --watch --configuration development",
    "build:test-app": "ng build --project test-app",
    "postinstall": "node environments/version.ts",
    "codegen": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 graphql-codegen --config codegen.yml",
    "link-dist": "cd dist/meshmakers/shared-auth && npm link && cd ../shared-services && npm link && cd ../shared-ui && npm link && cd ../octo-services && npm link && cd ../octo-ui && npm link",
    "lint": "eslint \"**/*.{ts, tsx}\"",
    "lint:fix": "eslint --fix \"**/*.{ts, tsx}\"",
    "prettier": "prettier --write ."
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^17.1.3",
    "@angular/cdk": "^17.1.2",
    "@angular/common": "^17.1.3",
    "@angular/compiler": "^17.1.3",
    "@angular/core": "^17.1.3",
    "@angular/flex-layout": "^15.0.0-beta.42",
    "@angular/forms": "^17.1.3",
    "@angular/material": "^17.1.2",
    "@angular/platform-browser": "^17.1.3",
    "@angular/platform-browser-dynamic": "^17.1.3",
    "@angular/router": "^17.1.3",
    "angular-oauth2-oidc": "^17.0.1",
    "apollo-angular": "^6.0.0",
    "date-fns": "^3.3.1",
    "rxjs": "~7.8.1",
    "tslib": "^2.6.2",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.1.3",
    "@angular-eslint/builder": "17.2.1",
    "@angular-eslint/eslint-plugin": "17.2.1",
    "@angular-eslint/eslint-plugin-template": "17.2.1",
    "@angular-eslint/schematics": "17.2.1",
    "@angular-eslint/template-parser": "17.2.1",
    "@angular/cli": "^17.1.3",
    "@angular/compiler-cli": "^17.1.3",
    "@graphql-codegen/cli": "^5.0.2",
    "@graphql-codegen/near-operation-file-preset": "^3.0.0",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.0",
    "@graphql-codegen/typescript-operations": "^4.1.2",
    "@types/jasmine": "~5.1.4",
    "@types/node": "^20.11.17",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "jasmine-core": "~5.1.2",
    "karma": "~6.4.2",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^17.1.2",
    "prettier": "^3.2.5",
    "run-script-os": "^1.1.6",
    "typescript": "~5.3.3"
  }
}
