{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "test-app": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/test-app",
      "sourceRoot": "projects/test-app/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/test-app",
            "index": "projects/test-app/src/index.html",
            "main": "projects/test-app/src/main.ts",
            "polyfills": "projects/test-app/src/polyfills.ts",
            "tsConfig": "projects/test-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/test-app/src/favicon.ico",
              "projects/test-app/src/assets"
            ],
            "styles": [
              "@angular/material/prebuilt-themes/purple-green.css",
              "projects/test-app/src/styles.scss"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "2kb",
                  "maximumError": "4kb"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "projects/test-app/src/environments/environment.ts",
                  "with": "projects/test-app/src/environments/environment.prod.ts"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "test-app:build:production"
            },
            "development": {
              "buildTarget": "test-app:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "test-app:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/test-app/src/test.ts",
            "polyfills": "projects/test-app/src/polyfills.ts",
            "tsConfig": "projects/test-app/tsconfig.spec.json",
            "karmaConfig": "projects/test-app/karma.conf.js",
            "inlineStyleLanguage": "scss",
            "assets": [
              "projects/test-app/src/favicon.ico",
              "projects/test-app/src/assets"
            ],
            "styles": [
              "@angular/material/prebuilt-themes/purple-green.css",
              "projects/test-app/src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "@meshmakers/octo-services": {
      "projectType": "library",
      "root": "projects/meshmakers/octo-services",
      "sourceRoot": "projects/meshmakers/octo-services/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/meshmakers/octo-services/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/meshmakers/octo-services/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/meshmakers/octo-services/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/meshmakers/octo-services/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    },
    "@meshmakers/octo-ui": {
      "projectType": "library",
