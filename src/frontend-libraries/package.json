{
  "name": "frontend-libraries",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "setup-license": "node scripts/setup-license.js",
    "prestart": "npm run setup-license",
    "start": "ng serve --port 4201 --ssl --ssl-cert localhost.crt --ssl-key localhost.key --configuration development",
    "prebuild": "npm run setup-license",
    "build": "npm run build:shared-services && npm run build:shared-auth && npm run build:shared-ui && npm run build:shared-ui-legacy && npm run build:octo-services && npm run build:octo-ui && npm run build:octo-ui-legacy && npm run build:octo-process-diagrams && npm run build:octo-meshboard && npm run build:demo-app",
    "prebuild:prod": "npm run setup-license",
    "build:prod": "npm run build:shared-services -- --configuration=production && npm run build:shared-auth -- --configuration=production && npm run build:shared-ui -- --configuration=production && npm run build:shared-ui-legacy -- --configuration=production && npm run build:octo-services -- --configuration=production && npm run build:octo-ui -- --configuration=production && npm run build:octo-ui-legacy -- --configuration=production && npm run build:octo-process-diagrams -- --configuration=production && npm run build:octo-meshboard -- --configuration=production && npm run build:demo-app -- --configuration=production",
    "watch": "ng build --watch --configuration development",
    "build:shared-auth": "ng lint @meshmakers/shared-auth && ng build @meshmakers/shared-auth",
    "build:shared-ui": "ng lint @meshmakers/shared-ui && ng build @meshmakers/shared-ui",
    "build:shared-ui-legacy": "ng lint @meshmakers/shared-ui-legacy && ng build @meshmakers/shared-ui-legacy",
    "build:octo-ui": "ng lint @meshmakers/octo-ui && ng build @meshmakers/octo-ui",
    "build:octo-ui-legacy": "ng lint @meshmakers/octo-ui-legacy && ng build @meshmakers/octo-ui-legacy",
    "build:octo-services": "ng lint @meshmakers/octo-services && ng build @meshmakers/octo-services",
    "build:octo-process-diagrams": "ng lint @meshmakers/octo-process-diagrams && ng build @meshmakers/octo-process-diagrams",
    "build:octo-meshboard": "ng lint @meshmakers/octo-meshboard && ng build @meshmakers/octo-meshboard",
    "watch:octo-meshboard": "ng build @meshmakers/octo-meshboard --watch --configuration development",
    "lint:octo-meshboard": "ng lint @meshmakers/octo-meshboard",
    "build:shared-services": "ng lint @meshmakers/shared-services && ng build @meshmakers/shared-services",
    "build:demo-app": "ng lint demo-app && ng build --project demo-app",
    "watch:shared-auth": "ng build @meshmakers/shared-auth --watch --configuration development",
    "watch:shared-services": "ng build @meshmakers/shared-services --watch --configuration development",
    "watch:shared-ui": "ng build @meshmakers/shared-ui --watch --configuration development",
    "watch:shared-ui-legacy": "ng build @meshmakers/shared-ui-legacy --watch --configuration development",
    "watch:octo-ui": "ng build @meshmakers/octo-ui --watch --configuration development",
    "watch:octo-ui-legacy": "ng build @meshmakers/octo-ui-legacy --watch --configuration development",
    "test": "ng test",
    "codegen": "cross-env NODE_OPTIONS=\"--max-old-space-size=16384\" graphql-codegen --config codegen.yml",
    "link-dist": "cd dist/meshmakers/shared-auth && npm link && cd ../shared-services && npm link && cd ../shared-ui && npm link && cd ../octo-services && npm link && cd ../octo-ui && npm link",
    "lint": "npm run lint:shared-services && npm run lint:shared-auth && npm run lint:shared-ui && npm run lint:shared-ui-legacy && npm run lint:octo-services && npm run lint:octo-process-diagrams && npm run lint:octo-meshboard && npm run lint:octo-ui && npm run lint:octo-ui-legacy && npm run lint:demo-app",
    "lint:shared-auth": "ng lint @meshmakers/shared-auth",
    "lint:shared-ui": "ng lint @meshmakers/shared-ui",
    "lint:shared-ui-legacy": "ng lint @meshmakers/shared-ui-legacy",
    "lint:octo-ui": "ng lint @meshmakers/octo-ui",
    "lint:octo-ui-legacy": "ng lint @meshmakers/octo-ui-legacy",
    "lint:octo-services": "ng lint @meshmakers/octo-services",
    "lint:octo-process-diagrams": "ng lint @meshmakers/octo-process-diagrams",
    "lint:shared-services": "ng lint @meshmakers/shared-services",
    "lint:demo-app": "ng lint demo-app",
    "postinstall": "node -e \"var s=require('path').join(__dirname,'projects/demo-app/src/environments/version.ts');require('fs').existsSync(s)?require('child_process').execSync('node \\\"'+s+'\\\"',{stdio:'inherit'}):console.log('Version generation skipped')\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.5",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.1.5",
    "@angular/compiler": "^21.1.5",
    "@angular/core": "^21.1.5",
    "@angular/forms": "^21.1.5",
    "@angular/localize": "^21.1.5",
    "@angular/material": "^21.1.5",
    "@angular/platform-browser": "^21.1.5",
    "@angular/platform-browser-dynamic": "^21.1.5",
    "@angular/router": "^21.1.5",
    "@apollo/client": "^4.1.3",
    "@progress/kendo-angular-buttons": "21.3.0",
    "@progress/kendo-angular-charts": "21.3.0",
    "@progress/kendo-angular-common": "21.3.0",
    "@progress/kendo-angular-dateinputs": "21.3.0",
    "@progress/kendo-angular-dialog": "21.3.0",
    "@progress/kendo-angular-dropdowns": "21.3.0",
    "@progress/kendo-angular-excel-export": "21.3.0",
    "@progress/kendo-angular-gauges": "21.3.0",
    "@progress/kendo-angular-grid": "21.3.0",
    "@progress/kendo-angular-icons": "21.3.0",
    "@progress/kendo-angular-indicators": "21.3.0",
    "@progress/kendo-angular-inputs": "21.3.0",
    "@progress/kendo-angular-intl": "21.3.0",
    "@progress/kendo-angular-l10n": "21.3.0",
    "@progress/kendo-angular-label": "21.3.0",
    "@progress/kendo-angular-layout": "21.3.0",
    "@progress/kendo-angular-menu": "21.3.0",
    "@progress/kendo-angular-navigation": "21.3.0",
    "@progress/kendo-angular-notification": "21.3.0",
    "@progress/kendo-angular-pager": "21.3.0",
    "@progress/kendo-angular-pdf-export": "21.3.0",
    "@progress/kendo-angular-popup": "21.3.0",
    "@progress/kendo-angular-progressbar": "21.3.0",
    "@progress/kendo-angular-treeview": "21.3.0",
    "@progress/kendo-angular-utils": "21.3.0",
    "@progress/kendo-data-query": "^1.7.2",
    "@progress/kendo-drawing": "^1.23.1",
    "@progress/kendo-licensing": "^1.8.0",
    "@progress/kendo-svg-icons": "^4.5.0",
    "@progress/kendo-theme-default": "^12.3.0",
    "angular-oauth2-oidc": "^20.0.2",
    "apollo-angular": "^13.0.0",
    "cron-parser": "^5.5.0",
    "cronstrue": "^3.11.0",
    "dockview-angular": "^4.13.1",
    "dockview-core": "^4.13.1",
    "expr-eval": "^2.0.2",
    "marked": "^17.0.0",
    "ngx-markdown": "^21.0.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "tus-js-client": "^4.2.3",
    "zone.js": "~0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.5",
    "@graphql-codegen/cli": "^6.1.0",
    "@graphql-codegen/fragment-matcher": "^6.0.0",
    "@graphql-codegen/near-operation-file-preset": "^4.0.0",
    "@graphql-codegen/typescript-apollo-angular": "^4.0.1",
    "@graphql-codegen/typescript-operations": "^5.0.7",
    "@types/expr-eval": "^1.0.2",
    "@types/jasmine": "~5.1.13",
    "angular-eslint": "21.1.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-unused-imports": "^4.3.0",
    "jasmine-core": "~5.13.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "karma-junit-reporter": "~2.0.1",
    "ng-packagr": "^21.0.1",
    "source-map-explorer": "^2.5.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.50.0"
  }
}
