{
  "$schema": "../../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../../dist/meshmakers/octo-ui",
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "assets": [
    {
      "input": "src/styles",
      "glob": "**/*.scss",
      "output": "styles"
    },
    {
      "input": "src/lib/runtime-browser/styles",
      "glob": "**/*.scss",
      "output": "lib/runtime-browser/styles"
    }
  ]
}
